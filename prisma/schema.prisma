generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  KEY
  ACCOUNT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InventoryItemStatus {
  AVAILABLE
  RESERVED
  SOLD
  DISCARDED
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String?
  pendingPasswordHash String?
  tokenVersion Int     @default(0)

  orders   Order[]
  products Product[]

  isEmailVerified             Boolean   @default(false)
  emailVerificationCode       Int?
  emailVerificationCodeExpire DateTime?
  passwordResetCode           Int?
  passwordResetCodeExpire     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  type        ProductType
  title       String
  description String
  price       Decimal

  inventory InventoryItem[]
  orders    Order[]

  userId String
  owner  User   @relation(fields: [userId], references: [id])

  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  paymentId      String?
  idempotenceKey String?
  purchaseEmailSentAt DateTime?

  priceAtSale Decimal
  status      PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  content Json
  status  InventoryItemStatus @default(AVAILABLE)

  order Order?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, status])
}
